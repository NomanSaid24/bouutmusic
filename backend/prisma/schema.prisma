// This is your Prisma schema file for Bouut Music platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          String    @default("ARTIST") // LISTENER, ARTIST, ADMIN
  slug          String?   @unique
  avatar        String?
  banner        String?
  bio           String?
  artistTypes   String?
  genre         String?
  country       String?
  state         String?
  city          String?
  website       String?
  instagram     String?
  facebook      String?
  twitter       String?
  youtube       String?
  spotify       String?
  isPro         Boolean   @default(false)
  proExpiresAt  DateTime?
  onboardingCompleted Boolean @default(false)
  profileProgress Int     @default(4)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  songs         Song[]
  albums        Album[]
  playlists     Playlist[]
  likes         Like[]
  follows       Follow[]    @relation("Follower")
  followers     Follow[]    @relation("Following")
  submissions   Submission[]
  payments      Payment[]
  notifications Notification[]
  posts         Post[]
  messages      Message[]   @relation("MessageSender")
  receivedMsgs  Message[]   @relation("MessageReceiver")
}

model Song {
  id          String      @id @default(cuid())
  title       String
  genre       String
  language    String
  year        Int         @default(2026)
  description String?
  audioUrl    String
  artUrl      String
  plays       Int         @default(0)
  downloads   Int         @default(0)
  status      String      @default("APPROVED") // PENDING, APPROVED, REJECTED
  privacy     String      @default("PUBLIC") // PUBLIC, PRIVATE
  featuredArtists String?
  pLine       String?
  cLine       String?
  isrc        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  artist      User        @relation(fields: [artistId], references: [id])
  artistId    String
  album       Album?      @relation(fields: [albumId], references: [id])
  albumId     String?
  playlistSongs PlaylistSong[]
  likes       Like[]
}

model Album {
  id          String    @id @default(cuid())
  title       String
  artUrl      String
  releaseDate DateTime
  genre       String?
  createdAt   DateTime  @default(now())

  artist      User      @relation(fields: [artistId], references: [id])
  artistId    String
  songs       Song[]
}

model Playlist {
  id          String    @id @default(cuid())
  name        String
  description String?
  artUrl      String?
  isPublic    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])
  userId      String
  songs       PlaylistSong[]
}

model PlaylistSong {
  playlist    Playlist  @relation(fields: [playlistId], references: [id])
  playlistId  String
  song        Song      @relation(fields: [songId], references: [id])
  songId      String
  order       Int       @default(0)

  @@id([playlistId, songId])
}

model Like {
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  song        Song      @relation(fields: [songId], references: [id])
  songId      String
  createdAt   DateTime  @default(now())

  @@id([userId, songId])
}

model Follow {
  follower    User      @relation("Follower", fields: [followerId], references: [id])
  followerId  String
  following   User      @relation("Following", fields: [followingId], references: [id])
  followingId String
  createdAt   DateTime  @default(now())

  @@id([followerId, followingId])
}

model Opportunity {
  id          String    @id @default(cuid())
  title       String
  type        String    // radio, publication, gig, contest
  description String
  deadline    DateTime
  isActive    Boolean   @default(true)
  reward      String?
  createdAt   DateTime  @default(now())

  submissions Submission[]
}

model Service {
  id          String    @id @default(cuid())
  name        String    // Demo Review, Playlist Promotion, Music Marketing, etc.
  description String
  price       Float
  features    String // SQLite cannot do String[], so stringify JSON
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  submissions Submission[]
}

model Submission {
  id          String            @id @default(cuid())
  type        String            // opportunity | service
  status      String            @default("PENDING") // PENDING_PAYMENT, PENDING, APPROVED, REJECTED
  paymentStatus String          @default("UNPAID") // UNPAID, PAID, FAILED, NOT_REQUIRED, REFUND_PENDING, REFUNDED, REFUND_FAILED
  paymentRequired Boolean       @default(false)
  paymentAmount Float?
  paymentCurrency String?
  paymentCompletedAt DateTime?
  reviewedAt  DateTime?
  reviewedById String?
  rejectionReason String?
  refundRequestedAt DateTime?
  refundedAt  DateTime?
  notes       String?
  adminNotes  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user        User              @relation(fields: [userId], references: [id])
  userId      String
  opportunity Opportunity?      @relation(fields: [opportunityId], references: [id])
  opportunityId String?
  service     Service?          @relation(fields: [serviceId], references: [id])
  serviceId   String?
  formData    String?           // Store JSON string of form data
  payment     Payment?
}

model Payment {
  id              String        @id @default(cuid())
  amount          Float
  currency        String        @default("INR")
  gateway         String        @default("payu")
  gatewayOrderId  String?
  gatewayPaymentId String?
  status          String        @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  type            String        // subscription | service
  description     String?
  amountSubtotal  Float?
  taxAmount       Float?
  billingName     String?
  billingEmail    String?
  billingPhone    String?
  billingAddress1 String?
  billingAddress2 String?
  billingCountry  String?
  billingCountryCode String?
  billingState    String?
  billingStateCode String?
  billingCity     String?
  billingPostalCode String?
  promoCode       String?
  payuTxnId       String?       @unique
  payuMihpayId    String?
  payuBankRefNum  String?
  payuPaymentMode String?
  payuStatus      String?
  payuUnmappedStatus String?
  payuHash        String?
  payuRequestPayload String?
  payuResponse    String?
  payuVerifiedResponse String?
  gatewayReceiptImageUrl String?
  refundStatus    String        @default("NONE") // NONE, INITIATED, REFUNDED, FAILED
  refundAmount    Float?
  refundRequestId String?
  refundTokenId   String?
  refundReason    String?
  refundResponse  String?
  refundRequestedAt DateTime?
  refundedAt      DateTime?
  failureMessage  String?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id])
  userId          String
  submission      Submission?   @relation(fields: [submissionId], references: [id])
  submissionId    String?       @unique
}

model PayuSettings {
  id                    String   @id @default(cuid())
  mode                  String   @default("test")
  isEnabled             Boolean  @default(false)
  merchantId            String?
  merchantKey           String?
  salt1Encrypted        String?
  salt2Encrypted        String?
  currency              String   @default("INR")
  productName           String   @default("Songdew Pro")
  originalAmount        Float    @default(4000)
  discountedAmount      Float    @default(2000)
  taxPercent            Float    @default(18)
  proDurationDays       Int      @default(365)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Post {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  body        String
  coverImage  String?
  tags        String // SQLite cannot do String[], so stringify JSON
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author      User      @relation(fields: [authorId], references: [id])
  authorId    String
}

model Notification {
  id          String    @id @default(cuid())
  type        String    // submission_approved, payment_success, new_opportunity, etc.
  title       String
  message     String
  read        Boolean   @default(false)
  link        String?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])
  userId      String
}

model Message {
  id          String    @id @default(cuid())
  content     String
  read        Boolean   @default(false)
  createdAt   DateTime  @default(now())

  sender      User      @relation("MessageSender", fields: [senderId], references: [id])
  senderId    String
  receiver    User      @relation("MessageReceiver", fields: [receiverId], references: [id])
  receiverId  String
}
