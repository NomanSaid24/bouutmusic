DATABASE_URL="file:./dev.db"
JWT_SECRET="change-this-jwt-secret"
JWT_REFRESH_SECRET="change-this-refresh-secret"
PAYU_SETTINGS_ENCRYPTION_KEY="change-this-encryption-key"
PAYU_SEED_MODE="test"
PAYU_SEED_ENABLED="true"
PAYU_SEED_MERCHANT_ID=""
PAYU_SEED_MERCHANT_KEY=""
PAYU_SEED_SALT1=""
PAYU_SEED_SALT2=""
PAYU_SEED_CURRENCY="INR"
PAYU_SEED_PRODUCT_NAME="Songdew Pro"
PAYU_SEED_ORIGINAL_AMOUNT="4000"
PAYU_SEED_DISCOUNTED_AMOUNT="2000"
PAYU_SEED_TAX_PERCENT="18"
PAYU_SEED_PRO_DURATION_DAYS="365"
PORT=3000
NODE_ENV=production
FRONTEND_URL="https://your-frontend-domain.com"
FRONTEND_URLS="https://your-frontend-domain.com"
BACKEND_PUBLIC_URL="https://api.your-domain.com"
UPLOAD_DIR=./uploads

# Email delivery for approval/rejection/refund notifications.
# PHP relay option: upload backend/public/mail-relay.php to a PHP-enabled path and set the same secret there.
PHP_MAIL_RELAY_URL="https://api.your-domain.com/mail-relay.php"
PHP_MAIL_RELAY_SECRET="replace-with-a-long-random-secret"
PHP_MAIL_RELAY_FROM="Bouut Music <support@bouutmusic.com>"

# No SMTP option: Resend sends over HTTPS API. Verify bouutmusic.com in Resend first.
RESEND_API_KEY=""
RESEND_FROM="Bouut Music <support@bouutmusic.com>"
ADMIN_REVIEW_EMAIL="support@bouutmusic.com"

# SMTP option: for Gmail, create an App Password; your normal Gmail password will not work.
GMAIL_USER="your-gmail-address@gmail.com"
GMAIL_APP_PASSWORD="your-16-character-gmail-app-password"
MAIL_FROM="Bouut Music <your-gmail-address@gmail.com>"

# Or use any SMTP provider instead of Gmail:
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER="your-gmail-address@gmail.com"
# SMTP_PASS="your-16-character-gmail-app-password"
